FROM registry.access.redhat.com/ubi9/python-312:latest@sha256:7adc9bee533e01ff0b98220b67d17aca1280344bf7ad0b663bfc84cee7e1adb5

USER root

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir --no-deps -r requirements.txt

COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir --no-deps .

EXPOSE 8000

USER 1001:1001

CMD ["uvicorn", "llm_d_latency_predictor.training_server:app", "--host", "0.0.0.0", "--port", "8000"]

LABEL com.redhat.component="odh-latency-predictor-training" \
      name="odh-latency-predictor-training" \
      description="Latency prediction training server for llm-d" \
      summary="Trains online ML models for TTFT/TPOT latency prediction" \
      io.k8s.display-name="odh-latency-predictor-training" \
      io.k8s.description="Latency prediction training server for llm-d"
